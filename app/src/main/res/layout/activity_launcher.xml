<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium Welcome Screen for Koda
  Light, airy, modern AI app aesthetic
  Reduced visual weight, better rhythm, clearer hierarchy
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:minHeight="600dp">

            <!-- ══════════════════════════════════════════
                 PREMIUM CARD - Reduced weight, better surfaces
                 ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                app:cardBackgroundColor="@color/koda_surface_1"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/koda_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ── Header: Logo + Title + Version ───────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- Logo -->
                        <ImageView
                            android:id="@+id/launcher_logo"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="centerCrop"
                            android:background="@drawable/launcher_logo_bg"
                            android:layout_marginEnd="12dp" />

                        <!-- Title group -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Koda"
                                android:textColor="@color/koda_text_primary"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI Coding Agent"
                                android:textColor="@color/koda_text_secondary"
                                android:textSize="13sp"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>

                        <!-- Refined version badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="v0.3"
                            android:textColor="@color/koda_text_tertiary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:background="@drawable/badge_version"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- ── Compact Code Preview ─────────────────────────────── -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/code_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/koda_surface_2"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/koda_stroke"
                        app:strokeWidth="0.5dp"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Terminal title bar - more compact -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <!-- Traffic lights - smaller -->
                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/dot_red"
                                    android:layout_marginEnd="4dp" />
                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/dot_yellow"
                                    android:layout_marginEnd="4dp" />
                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/dot_green"
                                    android:layout_marginEnd="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="koda ~ generating"
                                    android:textColor="@color/koda_text_tertiary"
                                    android:textSize="10sp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>

                            <!-- Code lines - more compact -->
                            <TextView
                                android:id="@+id/code_line_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="def fibonacci(n: int) -> list:"
                                android:textColor="@color/koda_primary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:alpha="0" />

                            <TextView
                                android:id="@+id/code_line_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="    seq = [0, 1]"
                                android:textColor="@color/koda_text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="1dp"
                                android:alpha="0" />

                            <TextView
                                android:id="@+id/code_line_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="    while len(seq) &lt; n:"
                                android:textColor="@color/koda_text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="1dp"
                                android:alpha="0" />

                            <TextView
                                android:id="@+id/code_line_4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="        seq.append(seq[-1] + seq[-2])"
                                android:textColor="@color/koda_text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="1dp"
                                android:alpha="0" />

                            <TextView
                                android:id="@+id/code_line_5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="    return seq"
                                android:textColor="@color/koda_success"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="1dp"
                                android:alpha="0" />

                            <!-- Cursor -->
                            <TextView
                                android:id="@+id/code_cursor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▋"
                                android:textColor="@color/koda_primary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:layout_marginTop="1dp"
                                android:alpha="0" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── Description - cleaner typography ─────────────────── -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Write, review and refine code with AI assistance. Powered by OpenClaude."
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.3"
                        android:layout_marginBottom="16dp" />

                    <!-- ── Battery Note - lighter, secondary ────────────────── -->
                    <LinearLayout
                        android:id="@+id/battery_block"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_battery"
                            android:tint="@color/koda_warning"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/launcher_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="For reliable background execution, grant unrestricted battery access."
                            android:textColor="@color/koda_text_tertiary"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- ── Premium CTA ───────────────────────────────────────── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/launcher_continue"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Continue"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/koda_primary"
                        android:textColor="@color/koda_on_primary"
                        app:rippleColor="@color/koda_ripple"
                        android:elevation="0dp"
                        android:stateListAnimator="@null" />

                    <!-- ── Secondary Action ─────────────────────────────────── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/launcher_skip"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_gravity="center_horizontal"
                        android:text="Skip for now"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:visibility="gone"
                        android:textColor="@color/koda_text_secondary"
                        app:rippleColor="@color/koda_ripple" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
