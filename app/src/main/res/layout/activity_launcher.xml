<?xml version="1.0" encoding="utf-8"?>
<!--
  Welcome / Launcher screen
  Structure:
    FrameLayout (full bg)
      └─ ScrollView (centers card on small screens)
           └─ LinearLayout (vertical, gravity=center)
                └─ MaterialCardView (hero card)
                     ├─ Branding block (logo + title + subtitle)
                     ├─ Code preview block (mini terminal animation)
                     ├─ Description
                     ├─ Battery info block
                     └─ CTAs (primary + secondary)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="@dimen/space_20"
            android:paddingTop="@dimen/space_32"
            android:paddingBottom="@dimen/space_32"
            android:minHeight="600dp">

            <!-- ══════════════════════════════════════════
                 HERO CARD - MaterialCardView
                 ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                app:cardBackgroundColor="@color/koda_surface_1"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="@dimen/elevation_md"
                app:strokeColor="@color/koda_stroke"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_24">

                    <!-- ── Branding block ───────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/space_20">

                        <!-- Logo -->
                        <ImageView
                            android:id="@+id/launcher_logo"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@mipmap/ic_launcher"
                            android:scaleType="centerCrop"
                            android:background="@drawable/launcher_logo_bg"
                            android:layout_marginEnd="@dimen/space_16" />

                        <!-- Title + subtitle -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Koda"
                                android:textColor="@color/koda_text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI Coding Agent"
                                android:textColor="@color/koda_text_tertiary"
                                android:textSize="13sp"
                                android:layout_marginTop="@dimen/space_2" />
                        </LinearLayout>

                        <!-- Version chip -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="v0.3"
                            android:textColor="@color/koda_text_tertiary"
                            android:textSize="11sp"
                            android:background="@drawable/chip_bg"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- ── Code preview (mini terminal) ─────── -->
                    <LinearLayout
                        android:id="@+id/code_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/code_preview_bg"
                        android:paddingHorizontal="@dimen/space_16"
                        android:paddingTop="@dimen/space_12"
                        android:paddingBottom="@dimen/space_16"
                        android:layout_marginBottom="@dimen/space_20">

                        <!-- Terminal title bar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/space_12">

                            <!-- Traffic lights -->
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/dot_red"
                                android:layout_marginEnd="5dp" />
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/dot_yellow"
                                android:layout_marginEnd="5dp" />
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginEnd="@dimen/space_12" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="koda ~ generating"
                                android:textColor="@color/koda_text_tertiary"
                                android:textSize="11sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <!-- Code lines — animated via Java -->
                        <TextView
                            android:id="@+id/code_line_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="def fibonacci(n: int) -> list:"
                            android:textColor="@color/koda_primary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:alpha="0" />

                        <TextView
                            android:id="@+id/code_line_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="    seq = [0, 1]"
                            android:textColor="@color/koda_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"
                            android:alpha="0" />

                        <TextView
                            android:id="@+id/code_line_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="    while len(seq) &lt; n:"
                            android:textColor="@color/koda_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"
                            android:alpha="0" />

                        <TextView
                            android:id="@+id/code_line_4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="        seq.append(seq[-1] + seq[-2])"
                            android:textColor="@color/koda_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"
                            android:alpha="0" />

                        <TextView
                            android:id="@+id/code_line_5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="    return seq"
                            android:textColor="@color/koda_success"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"
                            android:alpha="0" />

                        <!-- Cursor blink -->
                        <TextView
                            android:id="@+id/code_cursor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▋"
                            android:textColor="@color/koda_primary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="2dp"
                            android:alpha="0" />
                    </LinearLayout>

                    <!-- ── Description ──────────────────────── -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Write, review and refine code with OpenClaude-powered assistance from your phone."
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="@dimen/space_20" />

                    <!-- ── Battery info block ───────────────── -->
                    <LinearLayout
                        android:id="@+id/battery_block"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/battery_info_bg"
                        android:paddingHorizontal="@dimen/space_16"
                        android:paddingVertical="@dimen/space_12"
                        android:layout_marginBottom="@dimen/space_24">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡"
                            android:textSize="16sp"
                            android:layout_marginEnd="@dimen/space_12" />

                        <TextView
                            android:id="@+id/launcher_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="For reliable background execution, Koda needs unrestricted battery access."
                            android:textColor="@color/koda_text_secondary"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />
                    </LinearLayout>

                    <!-- ── CTAs ─────────────────────────────── -->
                    <Button
                        android:id="@+id/launcher_continue"
                        style="@style/Koda.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grant Battery Access"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/launcher_skip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Skip for now"
                        android:textColor="@color/koda_text_tertiary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:paddingVertical="@dimen/space_12"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
