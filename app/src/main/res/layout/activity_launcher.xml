<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="@dimen/space_40"
    android:paddingBottom="@dimen/space_64"
    android:background="@color/koda_bg"
    android:fitsSystemWindows="true">

    <!-- Icon -->
    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="🐾"
        android:textSize="44sp"
        android:gravity="center"
        android:background="@drawable/empty_state_icon_bg"
        android:layout_marginBottom="@dimen/space_20" />

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Koda"
        android:textSize="30sp"
        android:textColor="@color/koda_text_primary"
        android:textStyle="bold"
        android:letterSpacing="-0.02" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Coding Agent"
        android:textSize="14sp"
        android:textColor="@color/koda_text_tertiary"
        android:layout_marginTop="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_40" />

    <!-- Status message -->
    <TextView
        android:id="@+id/launcher_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Initializing…"
        android:textSize="13sp"
        android:textColor="@color/koda_text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="@dimen/space_24" />

    <!-- Continue / Grant button (hidden until needed) -->
    <Button
        android:id="@+id/launcher_continue"
        style="@style/Koda.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue"
        android:visibility="gone" />

</LinearLayout>
