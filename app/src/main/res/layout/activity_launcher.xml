<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium Welcome Screen v2 - Flat, airy, modern
  No heavy cards, glassmorphism, better contrast
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="28dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:minHeight="600dp">

            <!-- ══════════════════════════════════════════
                 HEADER - Logo + Title inline, minimal
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp"
                android:alpha="0"
                android:id="@+id/header_container">

                <ImageView
                    android:id="@+id/launcher_logo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_koda_logo"
                    android:scaleType="centerCrop"
                    android:background="@drawable/logo_background" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="0dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koda"
                    android:textColor="@color/koda_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="0dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v0.3"
                    android:textColor="@color/koda_text_tertiary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════
                 CODE PREVIEW - Compact, floating, glass effect
                 ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/code_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                app:cardBackgroundColor="@color/koda_surface_2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/koda_stroke"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Terminal bar minimal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/dot_red"
                            android:layout_marginEnd="3dp" />
                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/dot_yellow"
                            android:layout_marginEnd="3dp" />
                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/dot_green"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="generating..."
                            android:textColor="@color/koda_text_tertiary"
                            android:textSize="9sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Compact code - only 3 lines -->
                    <TextView
                        android:id="@+id/code_line_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="def solve(problem) -> Solution:"
                        android:textColor="@color/koda_primary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/code_line_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="    with AI.assistant() as ai:"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/code_line_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="        return ai.generate(problem)"
                        android:textColor="@color/koda_success"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/code_cursor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▋"
                        android:textColor="@color/koda_primary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:alpha="0" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════
                 TAGLINE - Simple, centered
                 ══════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI coding assistant"
                android:textColor="@color/koda_text_secondary"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <!-- ══════════════════════════════════════════
                 DESCRIPTION - Lighter, secondary
                 ══════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Write and refine code on your phone."
                android:textColor="@color/koda_text_tertiary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <!-- ══════════════════════════════════════════
                 ACTIONS - Premium outlined buttons
                 ══════════════════════════════════════════ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/launcher_continue"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:text="Get Started"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="24dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="@color/koda_primary"
                app:strokeColor="@color/koda_primary"
                app:strokeWidth="1.5dp"
                app:rippleColor="@color/koda_ripple" />

            <View
                android:layout_width="0dp"
                android:layout_height="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/launcher_skip"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Skip"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:visibility="gone"
                android:textColor="@color/koda_text_tertiary"
                app:rippleColor="@color/koda_ripple" />

            <!-- ══════════════════════════════════════════
                 BATTERY HINT - Minimal, icon only
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/battery_block"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:alpha="0.6">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_battery"
                    android:tint="@color/koda_warning" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/launcher_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Battery optimization recommended"
                    android:textColor="@color/koda_text_tertiary"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
