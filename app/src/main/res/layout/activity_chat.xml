<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0F172A"
        android:fitsSystemWindows="true">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:elevation="4dp">

            <!-- Menu button -->
            <ImageButton
                android:id="@+id/menu_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:tint="#94A3B8"
                android:scaleType="center" />

            <TextView
                android:id="@+id/chat_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Koda"
                android:textColor="#F8FAFC"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/model_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sonnet 4.6"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:background="@drawable/chip_background"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <!-- New chat button -->
            <ImageButton
                android:id="@+id/new_chat_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="New chat"
                android:tint="#7DD3FC"
                android:scaleType="center" />
        </LinearLayout>

        <!-- Chat area + FAB wrapper -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/chat_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/chat_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false" />
            </ScrollView>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:paddingHorizontal="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐾"
                    android:textSize="48sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koda"
                    android:textColor="#F1F5F9"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Coding Agent\nPowered by Claude · RelayGPU"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask me anything →"
                    android:textColor="#334155"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="32dp" />
            </LinearLayout>

            <!-- Scroll-to-bottom FAB -->
            <TextView
                android:id="@+id/scroll_fab"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:text="↓"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/send_button_background"
                android:visibility="gone"
                android:elevation="4dp" />

        </FrameLayout>

        <!-- Typing indicator -->
        <TextView
            android:id="@+id/typing_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● ● ●"
            android:textColor="#7DD3FC"
            android:textSize="18sp"
            android:letterSpacing="0.3"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:visibility="gone" />

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="#1E293B"
            android:gravity="bottom"
            android:elevation="8dp">

            <EditText
                android:id="@+id/chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Message..."
                android:textColor="#F8FAFC"
                android:textColorHint="#475569"
                android:background="@drawable/input_background"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textSize="15sp"
                android:minHeight="48dp"
                android:maxLines="6"
                android:scrollbars="vertical"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine|textCapSentences"
                android:lineSpacingExtra="2dp" />

            <ImageButton
                android:id="@+id/send_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="@drawable/send_button_background"
                android:contentDescription="Send"
                android:tint="#0F172A"
                android:scaleType="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Drawer (conversation list) -->
    <LinearLayout
        android:id="@+id/drawer_panel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#0F172A"
        android:fitsSystemWindows="true">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Conversations"
                android:textColor="#F8FAFC"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/drawer_new_chat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="New chat"
                android:tint="#7DD3FC"
                android:scaleType="center" />
        </LinearLayout>

        <!-- Conversation list -->
        <ListView
            android:id="@+id/conversation_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#1E293B"
            android:dividerHeight="1dp"
            android:background="#0F172A"
            android:scrollbars="none" />

        <!-- Settings button at bottom of drawer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="#1E293B"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/drawer_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:tint="#94A3B8"
                android:scaleType="center" />

            <TextView
                android:id="@+id/drawer_settings_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#94A3B8"
                android:textSize="15sp"
                android:paddingStart="8dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
