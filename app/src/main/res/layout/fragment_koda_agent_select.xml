<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="@color/koda_background">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/koda_choose_agent"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/koda_on_background"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="32dp" />

    <!-- Agent 1: OpenClaude -->
    <FrameLayout
        android:id="@+id/agent_openclaude_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/koda_card_bg"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Icon -->
            <ImageView
                android:id="@+id/agent_openclaude_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/agent_openclaude"
                android:contentDescription="@string/koda_openclaude"
                android:layout_marginEnd="16dp" />

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/koda_openclaude"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/koda_on_background"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/koda_openclaude_desc"
                    android:textSize="13sp"
                    android:textColor="@color/koda_secondary_text"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/agent_openclaude_url"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/koda_openclaude_site"
                    android:textSize="12sp"
                    android:textColor="#1976D2"
                    android:alpha="0.8" />

            </LinearLayout>

            <!-- Install/Open button -->
            <Button
                android:id="@+id/agent_openclaude_install"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="36dp"
                android:text="@string/koda_install"
                android:textSize="11sp"
                android:minWidth="72dp"
                android:background="@drawable/koda_button_bg"
                android:textColor="#1A1A1A"
                android:textStyle="bold" />

        </LinearLayout>
    </FrameLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/koda_surface"
        android:layout_marginBottom="12dp" />

    <!-- Agent 2: OwliaBot -->
    <LinearLayout
        android:id="@+id/agent_owliabot_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:alpha="0.5"
        android:background="@drawable/koda_card_bg">

        <!-- Icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/agent_owliabot"
            android:contentDescription="@string/koda_owliabot"
            android:layout_marginEnd="16dp" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/koda_owliabot"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/koda_on_background"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/koda_owliabot_desc"
                android:textSize="13sp"
                android:textColor="@color/koda_secondary_text"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/koda_owliabot_site"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:alpha="0.8" />

        </LinearLayout>

        <!-- Soon button (disabled) -->
        <Button
            android:id="@+id/agent_owliabot_soon"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/koda_soon"
            android:textSize="13sp"
            android:minWidth="80dp"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>
