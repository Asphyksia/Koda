<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg"
    android:fitsSystemWindows="true">

    <!-- ============================================================
         INSTALL PHASE
         ============================================================ -->
    <LinearLayout
        android:id="@+id/install_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_20"
            android:paddingTop="@dimen/space_32"
            android:paddingBottom="@dimen/space_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setting up Koda"
                android:textColor="@color/koda_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/space_8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Installing OpenClaude and dependencies…"
                android:textColor="@color/koda_text_tertiary"
                android:textSize="13sp"
                android:layout_marginTop="@dimen/space_4" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/install_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/koda_primary"
            android:progressTint="@color/koda_primary"
            android:visibility="gone" />

        <!-- Log output -->
        <ScrollView
            android:id="@+id/install_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:padding="@dimen/space_4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_surface"
                android:padding="@dimen/space_16"
                android:layout_margin="@dimen/space_16">

                <TextView
                    android:id="@+id/install_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/koda_text_secondary"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </ScrollView>

        <!-- Retry button (hidden until needed) -->
        <Button
            android:id="@+id/install_button"
            style="@style/Koda.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_16"
            android:text="Retry"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ============================================================
         CONFIG PHASE
         ============================================================ -->
    <ScrollView
        android:id="@+id/config_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:minHeight="100dp"
            android:paddingHorizontal="@dimen/space_24"
            android:paddingTop="@dimen/space_48"
            android:paddingBottom="@dimen/space_32">

            <!-- Branding -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾"
                android:textSize="40sp"
                android:gravity="center"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Almost there"
                android:textColor="@color/koda_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your API credentials to start chatting"
                android:textColor="@color/koda_text_tertiary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/space_4"
                android:layout_marginBottom="@dimen/space_32" />

            <!-- Form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_surface"
                android:padding="@dimen/space_20"
                android:layout_marginBottom="@dimen/space_16">

                <!-- API Key field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API KEY"
                    android:textColor="@color/koda_text_tertiary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_4" />

                <EditText
                    android:id="@+id/api_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="relay_sk_..."
                    android:textColor="@color/koda_text_primary"
                    android:textColorHint="@color/koda_text_tertiary"
                    android:background="@drawable/input_field_bg"
                    android:paddingHorizontal="@dimen/space_12"
                    android:paddingVertical="@dimen/space_12"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:inputType="textPassword"
                    android:layout_marginBottom="@dimen/space_16" />

                <!-- Base URL field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BASE URL"
                    android:textColor="@color/koda_text_tertiary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_4" />

                <EditText
                    android:id="@+id/base_url_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://relay.opengpu.network/v2/anthropic"
                    android:textColor="@color/koda_text_primary"
                    android:textColorHint="@color/koda_text_tertiary"
                    android:background="@drawable/input_field_bg"
                    android:paddingHorizontal="@dimen/space_12"
                    android:paddingVertical="@dimen/space_12"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:inputType="textUri" />

            </LinearLayout>

            <!-- Status message -->
            <TextView
                android:id="@+id/config_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/koda_error"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="@dimen/space_12" />

            <!-- Save button -->
            <Button
                android:id="@+id/save_button"
                style="@style/Koda.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Koda" />

            <!-- Fine print -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your API key is stored locally on this device only."
                android:textColor="@color/koda_text_tertiary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="@dimen/space_12" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
