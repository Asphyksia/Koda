<?xml version="1.0" encoding="utf-8"?>
<!--
  PREMIUM SETUP SCREEN
  Modern, technical, refined installation experience
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg">

    <!-- ═══════════════════════════════════════════════════════════════════
         PHASE 1: Premium Installation Experience
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/install_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Brand mark -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_k_logo"
            android:layout_marginBottom="24dp"
            android:alpha="0.9" />

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Install OpenClaude"
            android:textColor="@color/koda_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/install_step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 5"
            android:textColor="@color/koda_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="32dp" />

        <!-- Progress bar integrated with steps -->
        <ProgressBar
            android:id="@+id/install_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginBottom="32dp"
            android:progressTint="@color/koda_primary"
            android:progressBackgroundTint="@color/koda_surface_2" />

        <!-- Steps checklist -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <!-- Step 1 -->
            <LinearLayout
                android:id="@+id/step_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp">
                    <View
                        android:id="@+id/step_1_pending"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_pending" />
                    <View
                        android:id="@+id/step_1_current"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_current"
                        android:visibility="gone" />
                    <View
                        android:id="@+id/step_1_done"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_completed"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/step_1_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Building environment"
                    android:textColor="@color/koda_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/step_1_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/koda_text_quaternary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:id="@+id/step_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp">
                    <View
                        android:id="@+id/step_2_pending"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_pending" />
                    <View
                        android:id="@+id/step_2_current"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_current"
                        android:visibility="gone" />
                    <View
                        android:id="@+id/step_2_done"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_completed"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/step_2_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Installing Node.js"
                    android:textColor="@color/koda_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/step_2_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/koda_text_quaternary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:id="@+id/step_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp">
                    <View
                        android:id="@+id/step_3_pending"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_pending" />
                    <View
                        android:id="@+id/step_3_current"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_current"
                        android:visibility="gone" />
                    <View
                        android:id="@+id/step_3_done"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_completed"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/step_3_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Installing OpenClaude"
                    android:textColor="@color/koda_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/step_3_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/koda_text_quaternary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout
                android:id="@+id/step_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp">
                    <View
                        android:id="@+id/step_4_pending"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_pending" />
                    <View
                        android:id="@+id/step_4_current"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_current"
                        android:visibility="gone" />
                    <View
                        android:id="@+id/step_4_done"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_completed"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/step_4_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Verifying dependencies"
                    android:textColor="@color/koda_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/step_4_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/koda_text_quaternary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Step 5 -->
            <LinearLayout
                android:id="@+id/step_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp">
                    <View
                        android:id="@+id/step_5_pending"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_pending" />
                    <View
                        android:id="@+id/step_5_current"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_current"
                        android:visibility="gone" />
                    <View
                        android:id="@+id/step_5_done"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/step_completed"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/step_5_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Finalizing setup"
                    android:textColor="@color/koda_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/step_5_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/koda_text_quaternary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Microcopy / hint -->
        <TextView
            android:id="@+id/install_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This may take a few minutes"
            android:textColor="@color/koda_text_quaternary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Install button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/install_button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Install OpenClaude"
            android:textSize="15sp"
            android:textColor="@color/koda_on_primary"
            app:backgroundTint="@color/koda_primary"
            app:cornerRadius="12dp" />

        <!-- Success state -->
        <LinearLayout
            android:id="@+id/install_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/step_completed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to code"
                android:textColor="@color/koda_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OpenClaude is installed and ready"
                android:textColor="@color/koda_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Error state -->
        <LinearLayout
            android:id="@+id/install_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Installation failed"
                android:textColor="@color/koda_error"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/install_error_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/koda_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/install_show_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View details"
                android:textColor="@color/koda_primary"
                android:textSize="13sp"
                android:padding="8dp" />

            <ScrollView
                android:id="@+id/install_scroll"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_surface"
                android:padding="12dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/install_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/koda_text_secondary" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         PHASE 2: Provider Wizard (unchanged)
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/wizard_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@color/koda_surface_1">

            <TextView
                android:id="@+id/wizard_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Choose Provider"
                android:textColor="@color/koda_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Step indicators -->
            <LinearLayout
                android:id="@+id/step_indicators"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/step_dot_1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/step_current" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:background="@color/koda_stroke"
                    android:layout_marginHorizontal="4dp"/>

                <View
                    android:id="@+id/step_dot_2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/step_pending" />
            </LinearLayout>
        </LinearLayout>

        <!-- Wizard pages container -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- STEP 1: Choose Provider -->
                <LinearLayout
                    android:id="@+id/step1_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="RECOMMENDED"
                        android:textColor="@color/koda_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/providers_priority"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="MORE PROVIDERS"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/providers_secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>

                <!-- STEP 2: API Key -->
                <LinearLayout
                    android:id="@+id/step2_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter API Key"
                        android:textColor="@color/koda_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/step2_provider_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="For OpenRouter"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="sk-..."
                        app:endIconMode="password_toggle"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/api_key_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:fontFamily="monospace"
                            android:textSize="14sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Your key is stored locally and never shared"
                        android:textColor="@color/koda_text_quaternary"
                        android:textSize="12sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/save_key_button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Save and continue"
                        app:cornerRadius="12dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
