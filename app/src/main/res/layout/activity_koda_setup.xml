<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/koda_bg">

    <!-- ═══════════════════════════════════════════════════════════════
         PHASE 1: Install OpenClaude
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/install_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="🤖"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Install OpenClaude"
            android:textColor="@color/koda_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Setting up your AI coding agent…"
            android:textColor="@color/koda_text_secondary"
            android:textSize="13sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_surface"
            android:padding="16dp">

            <TextView
                android:id="@+id/install_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="start"
                android:text=""
                android:textColor="@color/koda_text_secondary"
                android:textSize="12sp" />
        </ScrollView>

        <ProgressBar
            android:id="@+id/install_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="20dp"
            android:indeterminate="true"
            android:progressTint="@color/koda_primary"
            android:visibility="gone" />

        <Button
            android:id="@+id/install_button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/btn_primary"
            android:paddingHorizontal="32dp"
            android:text="Install"
            android:textColor="@color/koda_on_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         PHASE 2: Provider Wizard
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/wizard_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@color/koda_surface_1">

            <TextView
                android:id="@+id/wizard_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Choose Provider"
                android:textColor="@color/koda_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Step indicators -->
            <LinearLayout
                android:id="@+id/step_indicators"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/step_dot_1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/step_dot_active" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="1dp"
                    android:background="@color/koda_stroke"
                    android:layout_marginHorizontal="4dp"/>

                <View
                    android:id="@+id/step_dot_2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/step_dot_inactive" />
            </LinearLayout>
        </LinearLayout>

        <!-- Wizard pages container (scrollable) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ───────── STEP 1: Choose Provider ───────── -->
                <LinearLayout
                    android:id="@+id/step1_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="visible">

                    <!-- Section: Priority providers -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="RECOMMENDED"
                        android:textColor="@color/koda_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/providers_priority"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp"/>

                    <!-- Section: Secondary providers -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="MORE PROVIDERS"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/providers_secondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp"/>

                    <!-- Section: Advanced -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="ADVANCED"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/providers_advanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp"/>

                </LinearLayout>

                <!-- ───────── STEP 2: Configure Provider ───────── -->
                <LinearLayout
                    android:id="@+id/step2_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <!-- Selected provider summary card -->
                    <LinearLayout
                        android:id="@+id/selected_provider_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/card_surface"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/selected_provider_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="⚡"
                            android:textSize="28sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/selected_provider_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RelayGPU"
                                android:textColor="@color/koda_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/selected_provider_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Multi-model relay"
                                android:textColor="@color/koda_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/change_provider_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change"
                            android:textColor="@color/koda_primary"
                            android:textSize="13sp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <!-- Access mode chips (hidden if only one mode) -->
                    <TextView
                        android:id="@+id/mode_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="ACCESS MODE"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/mode_chips_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp"
                        android:visibility="gone"/>

                    <!-- API Key field -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="API KEY"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/input_field_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/api_key_input"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Paste your API key…"
                            android:inputType="textPassword"
                            android:padding="14dp"
                            android:textColor="@color/koda_text_primary"
                            android:textColorHint="@color/koda_text_tertiary"
                            android:textSize="14sp"
                            android:singleLine="true" />

                        <TextView
                            android:id="@+id/toggle_key_visibility"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:gravity="center"
                            android:text="👁"
                            android:textSize="16sp"
                            android:layout_marginEnd="4dp"/>
                    </LinearLayout>

                    <!-- Custom endpoint URL (shown only for azure/custom) -->
                    <TextView
                        android:id="@+id/endpoint_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="ENDPOINT URL"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:visibility="gone"/>

                    <EditText
                        android:id="@+id/endpoint_url_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/input_field_bg"
                        android:hint="https://your-deployment.openai.azure.com/v1"
                        android:inputType="textUri"
                        android:padding="14dp"
                        android:textColor="@color/koda_text_primary"
                        android:textColorHint="@color/koda_text_tertiary"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                    <!-- Model selector -->
                    <TextView
                        android:id="@+id/model_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="MODEL"
                        android:textColor="@color/koda_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:id="@+id/model_chips_row1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/model_chips_row2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"/>

                    <!-- Custom model input -->
                    <EditText
                        android:id="@+id/model_custom_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/input_field_bg"
                        android:hint="Or type a model ID…"
                        android:inputType="text"
                        android:padding="14dp"
                        android:textColor="@color/koda_text_primary"
                        android:textColorHint="@color/koda_text_tertiary"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                    <!-- Status / validation feedback -->
                    <TextView
                        android:id="@+id/config_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:minHeight="20dp"
                        android:text=""
                        android:textColor="@color/koda_error"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Bottom action bar -->
        <LinearLayout
            android:id="@+id/wizard_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@color/koda_surface_1">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/btn_ghost"
                android:paddingHorizontal="20dp"
                android:text="Back"
                android:textColor="@color/koda_primary"
                android:textSize="14sp"
                android:visibility="gone"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/btn_primary"
                android:paddingHorizontal="28dp"
                android:text="Next →"
                android:textColor="@color/koda_on_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:enabled="false" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
