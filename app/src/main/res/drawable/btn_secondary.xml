<?xml version="1.0" encoding="utf-8"?>
<!-- Secondary outlined button — subtle tonal bg + primary stroke -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/koda_ripple">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/koda_primary_container" />
            <stroke android:width="@dimen/stroke_default" android:color="@color/koda_primary_dim" />
            <corners android:radius="@dimen/radius_md" />
        </shape>
    </item>
</ripple>
