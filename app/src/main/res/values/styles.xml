<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================
         KODA DESIGN SYSTEM — Styles
         Reusable styles for all components
         ============================================================ -->


    <!-- ── TEXT ─────────────────────────────────────────────────── -->

    <style name="Koda.Text.Primary">
        <item name="android:textColor">@color/koda_text_primary</item>
        <item name="android:textSize">@dimen/text_base</item>
    </style>

    <style name="Koda.Text.Secondary">
        <item name="android:textColor">@color/koda_text_secondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>

    <style name="Koda.Text.Tertiary">
        <item name="android:textColor">@color/koda_text_tertiary</item>
        <item name="android:textSize">@dimen/text_xs</item>
    </style>

    <style name="Koda.Text.Title">
        <item name="android:textColor">@color/koda_text_primary</item>
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Koda.Text.SectionHeader">
        <item name="android:textColor">@color/koda_text_tertiary</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>


    <!-- ── BUTTONS ───────────────────────────────────────────────── -->

    <!-- Primary: filled, high emphasis -->
    <style name="Koda.Button.Primary">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/koda_on_primary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">@dimen/space_16</item>
        <item name="android:paddingVertical">@dimen/space_8</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Secondary: tonal/outlined, medium emphasis -->
    <style name="Koda.Button.Secondary">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/koda_primary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">@dimen/space_16</item>
        <item name="android:paddingVertical">@dimen/space_8</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Ghost: no fill, text only, low emphasis -->
    <style name="Koda.Button.Ghost">
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/koda_text_secondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingHorizontal">@dimen/space_12</item>
        <item name="android:paddingVertical">@dimen/space_6</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Destructive: error color, for deletes/resets -->
    <style name="Koda.Button.Destructive">
        <item name="android:background">@drawable/btn_destructive</item>
        <item name="android:textColor">@color/koda_error</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingHorizontal">@dimen/space_12</item>
        <item name="android:paddingVertical">@dimen/space_6</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:gravity">center</item>
    </style>


    <!-- ── CARDS ─────────────────────────────────────────────────── -->

    <style name="Koda.Card">
        <item name="android:background">@drawable/card_surface</item>
        <item name="android:padding">@dimen/card_padding_h</item>
        <item name="android:elevation">@dimen/elevation_sm</item>
    </style>

    <style name="Koda.Card.Active">
        <item name="android:background">@drawable/card_surface_active</item>
        <item name="android:padding">@dimen/card_padding_h</item>
        <item name="android:elevation">@dimen/elevation_md</item>
    </style>


    <!-- ── INPUT ─────────────────────────────────────────────────── -->

    <style name="Koda.Input">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:textColor">@color/koda_text_primary</item>
        <item name="android:textColorHint">@color/koda_text_tertiary</item>
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:paddingHorizontal">@dimen/space_16</item>
        <item name="android:paddingVertical">@dimen/space_12</item>
    </style>


    <!-- ── CHIPS ─────────────────────────────────────────────────── -->

    <style name="Koda.Chip">
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:textColor">@color/koda_text_secondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingHorizontal">@dimen/space_10</item>
        <item name="android:paddingVertical">@dimen/space_4</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Koda.Chip.Active">
        <item name="android:background">@drawable/chip_bg_active</item>
        <item name="android:textColor">@color/koda_primary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingHorizontal">@dimen/space_10</item>
        <item name="android:paddingVertical">@dimen/space_4</item>
        <item name="android:gravity">center</item>
    </style>


    <!-- ── BADGES ────────────────────────────────────────────────── -->

    <style name="Koda.Badge">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">@dimen/space_8</item>
        <item name="android:paddingVertical">@dimen/space_4</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Koda.Badge.Active" parent="Koda.Badge">
        <item name="android:background">@drawable/badge_active</item>
        <item name="android:textColor">@color/koda_primary</item>
    </style>

    <style name="Koda.Badge.Success" parent="Koda.Badge">
        <item name="android:background">@drawable/badge_success</item>
        <item name="android:textColor">@color/koda_success</item>
    </style>

    <style name="Koda.Badge.Warning" parent="Koda.Badge">
        <item name="android:background">@drawable/badge_warning</item>
        <item name="android:textColor">@color/koda_warning</item>
    </style>

    <style name="Koda.Badge.Error" parent="Koda.Badge">
        <item name="android:background">@drawable/badge_error</item>
        <item name="android:textColor">@color/koda_error</item>
    </style>

</resources>
