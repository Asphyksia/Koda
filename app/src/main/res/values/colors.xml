<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================
         KODA DESIGN SYSTEM — Color Palette
         Navy charcoal dark theme, blue accent, semantic states
         ============================================================ -->

    <!-- Background layers (darkest → lightest) -->
    <color name="koda_bg">#FF0D1117</color>           <!-- base app background — near-black navy -->
    <color name="koda_surface_1">#FF161B22</color>    <!-- cards, elevated surfaces — slightly lighter -->
    <color name="koda_surface_2">#FF1C2128</color>    <!-- code blocks, secondary surfaces -->
    <color name="koda_surface_3">#FF21262D</color>    <!-- active states, selected items -->
    <color name="koda_surface_4">#FF2D333B</color>    <!-- hover / pressed overlays -->

    <!-- Glassmorphism / Premium surfaces -->
    <color name="koda_surface_glass">#0D161B22</color> <!-- 5% opacity surface for glass effect -->
    <color name="koda_surface_glass_border">#1AFFFFFF</color> <!-- 10% white border -->

    <!-- Dividers & strokes -->
    <color name="koda_stroke">#FF21262D</color>       <!-- subtle border on cards/inputs -->
    <color name="koda_stroke_strong">#FF30363D</color> <!-- more visible stroke when needed -->
    <color name="koda_divider">#FF161B22</color>      <!-- list dividers -->

    <!-- Primary - More vibrant blue -->
    <color name="koda_primary">#FF58A6FF</color>           <!-- brighter, more premium blue -->
    <color name="koda_primary_container">#FF1F6FEB</color> <!-- chip bg, selected state bg -->
    <color name="koda_primary_dim">#FF388BFD</color>       <!-- muted primary for secondary actions -->
    <color name="koda_on_primary">#FFFFFFFF</color>        <!-- text on primary bg -->

    <!-- Text hierarchy -->
    <color name="koda_text_primary">#FFF0F6FF</color>    <!-- main text — soft white -->
    <color name="koda_text_secondary">#FF8B9EAF</color>  <!-- labels, subtitles -->
    <color name="koda_text_tertiary">#FF4A5E70</color>   <!-- hints, placeholders, disabled -->
    <color name="koda_text_on_dark">#FFFFFFFF</color>    <!-- text on colored surfaces -->

    <!-- Semantic: Success (configured, active, ok) -->
    <color name="koda_success">#FF4CAF7D</color>           <!-- text/icon color -->
    <color name="koda_success_container">#FF0D2E1E</color> <!-- badge / indicator bg -->
    <color name="koda_success_dim">#FF1A4A30</color>       <!-- stroke on success -->

    <!-- Semantic: Warning (incomplete, missing key, attention) -->
    <color name="koda_warning">#FFF0A835</color>           <!-- text/icon color -->
    <color name="koda_warning_container">#FF2C1E06</color> <!-- badge bg -->
    <color name="koda_warning_dim">#FF4A3210</color>       <!-- stroke -->

    <!-- Semantic: Error (critical, destructive, failure) -->
    <color name="koda_error">#FFEF5350</color>             <!-- text/icon color -->
    <color name="koda_error_container">#FF2A0C0C</color>   <!-- badge bg -->
    <color name="koda_error_dim">#FF4A1515</color>         <!-- stroke -->

    <!-- User bubble -->
    <color name="koda_bubble_user">#FF1A3558</color>       <!-- user message bg -->
    <color name="koda_bubble_assistant">#FF161C26</color>  <!-- assistant message bg -->

    <!-- Ripple / pressed -->
    <color name="koda_ripple">#1A4A90D9</color>            <!-- 10% primary -->
    <color name="koda_ripple_light">#0FFFFFFF</color>      <!-- 6% white for light surfaces -->

    <!-- Scrim -->
    <color name="koda_scrim">#CC000000</color>             <!-- drawer backdrop -->

</resources>
